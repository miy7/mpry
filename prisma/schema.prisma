generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  employee
  leader
  admin
  manager
  dev
}

enum UserStatus {
  active
  inactive
  suspended
}

enum PlanAssignmentRole {
  employee
  leader
}

enum AttendanceStatus {
  draft
  pending_leader_approval
  approved
  rejected
}

enum ApprovalDecision {
  pending
  approved
  rejected
}

enum PaymentStatus {
  paid
  unpaid
}

model User {
  id            String      @id @default(cuid())
  name          String?
  username      String      @unique
  email         String?     @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  phone         String?
  role          UserRole    @default(employee)
  status        UserStatus  @default(active)
  lastLoginAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  profile               EmployeeProfile?
  accounts              Account[]
  sessions              Session[]
  ledTeams              Team[]               @relation("TeamLeader")
  createdWorkPlans      WorkPlan[]           @relation("WorkPlanCreatedBy")
  updatedWorkPlans      WorkPlan[]           @relation("WorkPlanUpdatedBy")
  submittedAttendances  Attendance[]         @relation("AttendanceSubmittedBy")
  approvalsGiven        AttendanceApproval[] @relation("AttendanceApprovalBy")
  paymentRecordsUpdated PaymentRecord[]      @relation("PaymentRecordUpdatedBy")
  assignedProfiles      EmployeeProfile[]    @relation("ProfileLeader")
}

model EmployeeProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  employeeCode  String   @unique
  firstNameTh   String
  lastNameTh    String
  nickname      String?
  phone         String?
  bankAccountNo String?
  bankName      String?
  positionTitle String
  teamId        String?
  leaderId      String?
  isActive      Boolean  @default(true)
  startedAt     DateTime?
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  team           Team?                @relation(fields: [teamId], references: [id], onDelete: SetNull)
  leader         User?                @relation("ProfileLeader", fields: [leaderId], references: [id], onDelete: SetNull)
  planAssignments WorkPlanAssignment[]
  attendances    Attendance[]
  paymentRecords PaymentRecord[]

  @@index([teamId])
  @@index([leaderId])
}

model Team {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  leaderId    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  leader         User?           @relation("TeamLeader", fields: [leaderId], references: [id], onDelete: SetNull)
  members        EmployeeProfile[]
  workPlans      WorkPlan[]
  attendances    Attendance[]
  paymentRecords PaymentRecord[]

  @@index([leaderId])
}

model WorkPlan {
  id             String   @id @default(cuid())
  teamId         String?
  workDate       DateTime
  title          String
  jobSiteName    String
  jobSiteAddress String?
  detail         String?
  note           String?
  createdById    String
  updatedById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  team        Team?                @relation(fields: [teamId], references: [id], onDelete: SetNull)
  createdBy   User                 @relation("WorkPlanCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy   User?                @relation("WorkPlanUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  assignments WorkPlanAssignment[]

  @@index([workDate])
  @@index([teamId, workDate])
}

model WorkPlanAssignment {
  id                String             @id @default(cuid())
  workPlanId        String
  employeeProfileId String
  assignmentRole    PlanAssignmentRole @default(employee)
  note              String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  workPlan        WorkPlan        @relation(fields: [workPlanId], references: [id], onDelete: Cascade)
  employeeProfile EmployeeProfile @relation(fields: [employeeProfileId], references: [id], onDelete: Cascade)

  @@unique([workPlanId, employeeProfileId])
  @@index([employeeProfileId])
}

model Attendance {
  id                String           @id @default(cuid())
  employeeProfileId String
  submittedById     String
  teamId            String?
  workDate          DateTime
  clockInAt         DateTime?
  clockOutAt        DateTime?
  totalMinutes      Int              @default(0)
  status            AttendanceStatus @default(draft)
  note              String?
  lockedAt          DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  employeeProfile EmployeeProfile      @relation(fields: [employeeProfileId], references: [id], onDelete: Cascade)
  submittedBy     User                 @relation("AttendanceSubmittedBy", fields: [submittedById], references: [id], onDelete: Restrict)
  team            Team?                @relation(fields: [teamId], references: [id], onDelete: SetNull)
  approval        AttendanceApproval?

  @@unique([employeeProfileId, workDate])
  @@index([teamId, workDate])
  @@index([status, workDate])
}

model AttendanceApproval {
  id          String           @id @default(cuid())
  attendanceId String          @unique
  approverId  String
  decision    ApprovalDecision @default(pending)
  decidedAt   DateTime?
  reason      String?
  note        String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  attendance Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  approver   User       @relation("AttendanceApprovalBy", fields: [approverId], references: [id], onDelete: Restrict)

  @@index([approverId, decision])
}

model PaymentRecord {
  id                String        @id @default(cuid())
  employeeProfileId String
  teamId            String?
  periodStart       DateTime
  periodEnd         DateTime
  totalHours        Decimal       @db.Decimal(10, 2)
  totalWorkedDays   Decimal       @db.Decimal(10, 2)
  equivalentDays    Decimal       @db.Decimal(10, 2)
  payAmount         Decimal?      @db.Decimal(12, 2)
  status            PaymentStatus @default(unpaid)
  paidAt            DateTime?
  note              String?
  updatedById       String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  employeeProfile EmployeeProfile @relation(fields: [employeeProfileId], references: [id], onDelete: Cascade)
  team            Team?           @relation(fields: [teamId], references: [id], onDelete: SetNull)
  updatedBy       User?           @relation("PaymentRecordUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([employeeProfileId, periodStart, periodEnd])
  @@index([status, periodStart, periodEnd])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
